{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "backend: install dependencies",
      "type": "shell",
      "command": "${workspaceFolder}/backend/.venv/bin/python",
      "args": [
        "-m",
        "pip",
        "install",
        "-r",
        "${workspaceFolder}/backend/requirements.txt"
      ],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "backend: install editable",
      "type": "shell",
      "command": "${workspaceFolder}/backend/.venv/bin/python",
      "args": [
        "-m",
        "pip",
        "install",
        "-e",
        "."
      ],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "backend: alembic upgrade head",
      "type": "shell",
      "command": "${workspaceFolder}/backend/.venv/bin/python",
      "args": [
        "-m",
        "alembic",
        "upgrade",
        "head"
      ],
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": {
          "PYTHONPATH": "${workspaceFolder}/backend/src"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "frontend: npm install",
      "type": "shell",
      "command": "npm",
      "args": [
        "install"
      ],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": []
    },
    {
      "label": "frontend: ng serve",
      "type": "npm",
      "script": "start",
      "path": "frontend/",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "source": "angular",
        "applyTo": "closedDocuments",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*$",
          "endsPattern": ".*(Local:|Angular Live Development Server is listening|Application bundle generation complete).*"
        }
      }
    }
  ]
}
