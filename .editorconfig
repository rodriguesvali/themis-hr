root = true

[*.{py,ts,js,json,md,mdc,yml,yaml,sh}]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.py]
indent_size = 4

[.env.example]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
